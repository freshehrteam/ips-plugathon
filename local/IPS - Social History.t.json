    "termDefinitions" : {
      "en" : {
        "at0000.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0000.1",
          "text" : "IPS - Social History",
          "description" : "A persistent and evolving summary record of information about lifestyle risk factors that may influence health outcomes, clinical decision-making and provision of care."
        }
      },
      "de" : {
        "at0000.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0000.1",
          "text" : "IPS - Social History",
          "description" : "Eine beständige und sich entwickelnde Zusammenfassung von Informationen über Lifestyle-Risikofaktoren, die den gesundheitlichen Zustand, die klinische Entscheidungsfindung und die Gesundheitsversorgung beeinflussen könnten."
        }
      },
      "nl" : {
        "at0000.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0000.1",
          "text" : "IPS - Social History",
          "description" : "Een blijvende en voortschrijdende samenvatting van informatie over leefstijlkeuzes en activiteiten vast te leggen die van invloed kunnen zijn op klinische beslissingen en levering van zorg."
        }
      },
      "el" : {
        "at0000.1" : {
          "@type" : "ARCHETYPE_TERM",
          "code" : "at0000.1",
          "text" : "IPS - Social History",
          "description" : "Ένα επίμονο και εξελισσόμενο συνοπτικό αρχείο πληροφοριών σχετικά με τους παράγοντες κινδύνου του τρόπου ζωής που μπορεί να επηρεάσουν τα αποτελέσματα της υγείας, τη λήψη κλινικών αποφάσεων και την παροχή φροντίδας."
        }
      }
    },
